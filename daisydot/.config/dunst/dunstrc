[global]
    monitor = 0
    follow = mouse
    width = 350
    height = 100
    origin = top-right
    offset = 12x12
    notification_limit = 5
    progress_bar = true
    indicate_hidden = yes
    shrink = no
    separator_height = 2
    separator_color = "#504945"
    padding = 12
    horizontal_padding = 14
    frame_width = 2
    frame_color = "#d8a657"
    idle_threshold = 120
    font = JetBrainsMono Nerd Font 10
    line_height = 0
    markup = full
    format = "<b>%s</b>\n%b"
    alignment = left
    vertical_alignment = center
    show_age_threshold = 60
    word_wrap = yes
    ellipsize = middle
    ignore_newline = no
    stack_duplicates = true
    hide_duplicate_count = false
    show_indicators = yes
    icon_position = left
    min_icon_size = 24
    max_icon_size = 48
    icon_theme = "Numix-Circle"
    enable_recursive_icon_lookup = true
    corner_radius = 6
    mouse_left_click = close_current
    mouse_middle_click = do_action, close_current
    mouse_right_click = close_all
    layer = overlay

[urgency_low]
    background = "#282828"
    foreground = "#d4be98"
    frame_color = "#504945"
    timeout = 5

[urgency_normal]
    background = "#282828"
    foreground = "#d4be98"
    frame_color = "#d8a657"
    timeout = 10

[urgency_critical]
    background = "#282828"
    foreground = "#ea6962"
    frame_color = "#ea6962"
    timeout = 0
