# Daisydot — stable Ghostty config with Gruvbox Material theme

font-family = "JetBrainsMono Nerd Font"
font-size = 12

# Decorations and window setup
window-decoration = auto
maximize = true
title = "Daisydot Terminal"

# Theme (downloaded manually)
theme = gruvbox-material-medium-dark

# Keybindings — Windows-like copy/paste + tabs
keybind = ctrl+v=paste_from_clipboard
keybind = ctrl+shift+v=paste_from_clipboard
keybind = ctrl+c=copy_to_clipboard
keybind = ctrl+shift+c=copy_to_clipboard
keybind = shift+insert=paste_from_clipboard
keybind = ctrl+insert=copy_to_clipboard

keybind = ctrl+t=new_tab
keybind = ctrl+w=close_tab
keybind = ctrl+tab=next_tab
keybind = ctrl+shift+tab=previous_tab


# font fixes
font-size = 12
window-padding-x = 6
window-padding-y = 6
keybind = shift+enter=text:\x1b\r
